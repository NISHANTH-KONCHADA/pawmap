# ============================================================
# PawMap — Environment Variable Reference
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# ============================================================

# ── Database ────────────────────────────────────────────────
# MongoDB Atlas connection string
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=pawmap"

# ── Authentication ──────────────────────────────────────────
# Strong random secret used for JWT signing (magic-link auth)
JWT_SECRET="YOUR_SUPER_SECRET_JWT_KEY_HERE"

# ── Cloudinary (media uploads) ──────────────────────────────
CLOUDINARY_URL="cloudinary://<api_key>:<api_secret>@<cloud_name>"
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── AI APIs ─────────────────────────────────────────────────
# Groq — primary vision model for cat photo analysis
GROQ_API_KEY=""
# Gemini — fallback vision model (auto-injected in AI Studio)
GEMINI_API_KEY=""

# ── Server ──────────────────────────────────────────────────
# Port the server listens on. GCP Cloud Run overrides this with $PORT.
PORT=3000
# "development" | "production"
NODE_ENV=development

# ── CORS / Socket.io ────────────────────────────────────────
# URL of the frontend client (used for CORS + Socket.io origins)
CLIENT_URL="http://localhost:5173"

# ── Email (optional) ────────────────────────────────────────
# Leave blank in development — magic links are printed to terminal instead.
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# ── Temporal (optional) ─────────────────────────────────────
# Address of a real Temporal server. Leave blank to use the
# built-in simulated workflow engine.
TEMPORAL_ADDRESS=""
